# script exits on the first unset variable encountered
set -u    # nounset
# script stops on first command failure
set -e    # errexit
# ensures that if any command in a set of piped commands failed, the overall
# exit status is the status of the failed command
set -o pipefail

VERSION=0.1

# Filename of this script
SCRIPT=${0##*/}

# Help text for this script
HELP=\
"usage: $SCRIPT [-dh] [--version]

Download pi binary release from...

https://github.com/earendil-works/pi

...to a ~/opt directory in the user home-directory with a symlink
in ~/bin.

If no version is specified, the latest release is downloaded.

optional arguments:
  -d, --debug          enable verbose output
  -h, --help           show this help message
  --version            program version number "

_DEBUG=${_DEBUG:-false}
_debug() {
        if [ "$_DEBUG" = "true" ]; then
                echo 1>&2 "Debug: $@"
        fi
}

_error() {
        echo 1>&2 "Error: $@"
        exit 1
}

# Parse the command line options
ARGS=$(getopt -o dh -l "debug,help,version" -- "$@")
eval set -- "$ARGS"
while true; do
        case "$1" in
        -d|--debug)
                _DEBUG=true
                shift
                ;;
        -h|--help)
                echo "$HELP"
                exit 0
                ;;
        --version)
                echo $VERSION
                exit 0
                ;;
        --)
                shift
                break
                ;;
        *)
                break
                ;;
        esac
done

# check dependencies...
for cmd in \
        curl \
        jq \
        sha256sum \
        tar
do
        command -v $cmd &>/dev/null || _error "$cmd command not in \$PATH"
done

# determine architecture
arch=$(uname -m)
case "$arch" in
        x86_64)
                platform="x64"
                ;;
        aarch64|arm64)
                platform="arm64"
                ;;
        *)
                _error "Unsupported architecture: $arch"
                ;;
esac

# fetch the latest release info (tag + asset digest) in one API call
api_response=$(curl -s https://api.github.com/repos/earendil-works/pi/releases/latest)
tag=$(echo "$api_response" | jq -r '.tag_name')
version=${tag#v}
echo -n "pi $version (linux-${platform}): "

# extract the sha256 digest for our platform tarball from the API response
checksum=$(
        echo "$api_response" \
                | jq -r ".assets[] | select(.name == \"pi-linux-${platform}.tar.gz\") | .digest" \
                | sed 's/^sha256://'
)
test -n "$checksum" || _error "could not retrieve checksum from API"

# download tarball and checksums file to /tmp
cd /tmp

tarball="pi-linux-${platform}.tar.gz"
curl -s -L "https://github.com/earendil-works/pi/releases/download/${tag}/${tarball}" \
        -o "$tarball"
test -f "$tarball" || _error "download of tarball unsuccessful"

# verify the checksum of the tarball
if echo "$checksum  $tarball" | sha256sum --status --check
then
        # install pi
        test -d ~/opt || mkdir ~/opt
        test -d ~/bin || mkdir ~/bin
	tar -C ~/opt -xvzf "$tarball" --transform "s|^pi/|pi-${version}/|"
        ln -sf ~/opt/pi-${version}/pi ~/bin/pi
        echo "installed to ~/opt/pi-${version}"
else
        _error "checksum verification unsuccessful"
fi

# clean up
rm -f "$tarball"

~/bin/pi --version

exit 0
